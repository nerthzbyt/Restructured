# Copiar a .env: cp .env.example .env
#
# MODO PRINCIPAL (recomendado):
#   python NerT_AI_PRO/main.py run --host 127.0.0.1 --port 8787
#   UI: http://127.0.0.1:8787  |  API: http://127.0.0.1:8787/api
#
# NO correr Nertzh.py (8081) y NerT AI PRO (8787) simultáneamente.

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_ENV=demo
LIVE_TRADING_ENABLED=false

LLM_BACKEND=qwen_desktop
LLM_MODEL=qwen-plus-latest
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_S=120

SYMBOL=BTCUSDT
TIMEFRAME=1m
ORDER_TYPE=Limit
TIME_IN_FORCE=GTC
CAPITAL_USDT=2000.0
COMBINED_BUY_THRESHOLD=4.5
COMBINED_SELL_THRESHOLD=-4.5
COMBINED_HOLD_BAND=1.5
METRICS_WINDOW_MINUTES=15.0